MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_PREFIX=solar_assistant
MQTT_CLIENT_ID=mqtt-bridge
PORT=5003
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# InfluxDB — set these to enable time-series history writing.
# Leave INFLUX_URL empty to disable InfluxDB writes (safe default).
# ---------------------------------------------------------------------------
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=
INFLUX_ORG=home
INFLUX_BUCKET=solar
